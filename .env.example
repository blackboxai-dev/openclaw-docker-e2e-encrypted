# Copy this file to `.env` and fill in what you need.
#   cp .env.example .env

# REQUIRED — your organisation's confidential-compute host, e.g.
#   https://acme.blackbox.ai
# The proxy will call ${ENC_MODEL_URL}/enc/${ENC_MODEL_ID}/{attestation,message,message_stream}.
ENC_MODEL_URL=https://{organisation}.blackbox.ai

# OPTIONAL — model path segment under /enc/. Defaults to google/gemma-4-31b-it.
# ENC_MODEL_ID=google/gemma-4-31b-it

# OPTIONAL — default upstream BLACKBOX AI API key. Used as a fallback when a
# client doesn't send its own Authorization header. Leave commented/empty to
# require every request to bring its own key.
# BLACKBOX_API_KEY=sk-REPLACE-ME

# OPTIONAL — BYO-key pass-through. When 1 (default) the proxy forwards each
# client's `Authorization: Bearer <sk-...>` header upstream verbatim, so every
# caller uses their own key end-to-end. Set to 0 to always use BLACKBOX_API_KEY.
# PASSTHROUGH_API_KEY=1
